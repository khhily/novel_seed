@model NovelSeed.Controllers.InspirationsController.InspirationsIndexVm

@{
    ViewData["Title"] = "Inspirations";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
    <div class="d-flex align-items-center gap-2">
        <h1 class="h3 mb-0">Inspirations</h1>
        <a class="btn btn-sm btn-outline-primary" asp-controller="Workflows" asp-action="Run">启动工作流</a>
    </div>
    <div class="text-muted small">Total: @Model.TotalCount</div>
</div>

<form class="row g-2 align-items-center mb-3" method="get" asp-controller="Inspirations" asp-action="Index">
    <div class="col-12 col-md-6">
        <div class="input-group">
            <input class="form-control" type="search" name="q" value="@Model.Query" placeholder="搜索 Topic / Name / Seed" />
            <button class="btn btn-primary" type="submit">搜索</button>
        </div>
    </div>
    <div class="col-12 col-md-auto">
        <a class="btn btn-outline-secondary w-100" asp-controller="Inspirations" asp-action="Index">清空</a>
    </div>
    <input type="hidden" name="page" value="1" />
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
</form>

<div class="d-md-none">
    <div class="vstack gap-2">
        @foreach (var item in Model.Items)
        {
            <div class="card">
                <div class="card-body">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        @if (!string.IsNullOrWhiteSpace(item.Topic))
                        {
                            <span class="badge text-bg-primary">@item.Topic</span>
                        }
                        <span class="text-muted small">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                    </div>
                    <div class="fw-semibold mb-2">@item.Name</div>
                    <div class="seed-text">@item.Seed</div>
                </div>
            </div>
        }
    </div>
</div>

<div class="d-none d-md-block">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
            <tr>
                <th style="width: 180px;">Created</th>
                <th style="width: 160px;">Topic</th>
                <th style="width: 220px;">Name</th>
                <th>Seed</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="text-muted">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@item.Topic</td>
                    <td><strong>@item.Name</strong></td>
                    <td class="seed-text">@item.Seed</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3" aria-label="Pagination">
        <ul class="pagination justify-content-center flex-wrap">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-controller="Inspirations"
                   asp-action="Index"
                   asp-route-q="@Model.Query"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-pageSize="@Model.PageSize">上一页</a>
            </li>

            @if (Model.StartPage > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-controller="Inspirations"
                       asp-action="Index"
                       asp-route-q="@Model.Query"
                       asp-route-page="1"
                       asp-route-pageSize="@Model.PageSize">1</a>
                </li>
                @if (Model.StartPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }

            @for (var p = Model.StartPage; p <= Model.EndPage; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link"
                       asp-controller="Inspirations"
                       asp-action="Index"
                       asp-route-q="@Model.Query"
                       asp-route-page="@p"
                       asp-route-pageSize="@Model.PageSize">@p</a>
                </li>
            }

            @if (Model.EndPage < Model.TotalPages)
            {
                @if (Model.EndPage < Model.TotalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item">
                    <a class="page-link"
                       asp-controller="Inspirations"
                       asp-action="Index"
                       asp-route-q="@Model.Query"
                       asp-route-page="@Model.TotalPages"
                       asp-route-pageSize="@Model.PageSize">@Model.TotalPages</a>
                </li>
            }

            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-controller="Inspirations"
                   asp-action="Index"
                   asp-route-q="@Model.Query"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-pageSize="@Model.PageSize">下一页</a>
            </li>
        </ul>
    </nav>
}
